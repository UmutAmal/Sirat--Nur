  "duaMeaning1": "ಇನ್ನು ಕೆಲವರು, ‘ನಮ್ಮ ಪ್ರಭುವೇ, ನಮಗೆ ಇಹಲೋಕದಲ್ಲಿ ಮತ್ತು ಪರಲೋಕದಲ್ಲಿ ಒಳ್ಳೆಯದನ್ನು ನೀಡು ಮತ್ತು ಬೆಂಕಿಯ ಯಾತನೆಯಿಂದ ನಮ್ಮನ್ನು ರಕ್ಷಿಸು’ ಎಂದು ಪ್ರಾರ್ಥಿಸುತ್ತಾರೆ.",
  "duaMeaning2": "ದೇವರು ಯಾವುದೇ ಆತ್ಮಕ್ಕೆ ಸಹಿಸಲಾಗದಷ್ಟು ಹೊರೆಯಾಗುವುದಿಲ್ಲ: ಪ್ರತಿಯೊಬ್ಬರೂ ತಾನು ಮಾಡಿದ ಒಳ್ಳೆಯದನ್ನು ಗಳಿಸುತ್ತಾರೆ ಮತ್ತು ಅದರ ಕೆಟ್ಟದ್ದನ್ನು ಅನುಭವಿಸುತ್ತಾರೆ - ಕರ್ತನೇ, ನಾವು ಮರೆತರೆ ಅಥವಾ ತಪ್ಪುಗಳನ್ನು ಮಾಡಿದರೆ ನಮ್ಮನ್ನು ತರಾಟೆಗೆ ತೆಗೆದುಕೊಳ್ಳಬೇಡಿ. ಕರ್ತನೇ, ನೀನು ನಮ್ಮ ಹಿಂದಿನವರಿಗೆ ಹೊರೆಯಾಗಿರುವಂತೆ ನಮ್ಮ ಮೇಲೆ ಹೊರೆ ಹಾಕಬೇಡ. ಕರ್ತನೇ, ನಾವು ಸಹಿಸಿಕೊಳ್ಳುವ ಶಕ್ತಿಗಿಂತ ಹೆಚ್ಚಿನ ಹೊರೆಯನ್ನು ನಮಗೆ ನೀಡಬೇಡಿ. ನಮ್ಮನ್ನು ಕ್ಷಮಿಸಿ, ನಮ್ಮನ್ನು ಕ್ಷಮಿಸಿ ಮತ್ತು ನಮ್ಮ ಮೇಲೆ ಕರುಣಿಸು. ನೀನೇ ನಮ್ಮ ರಕ್ಷಕ, ಆದ್ದರಿಂದ ನಂಬಿಕೆ ದ್ರೋಹಿಗಳ ವಿರುದ್ಧ ನಮಗೆ ಸಹಾಯ ಮಾಡಿ.",
  "duaMeaning3": "‘ನಮ್ಮ ಪ್ರಭುವೇ, ನೀನು ನಮಗೆ ಮಾರ್ಗದರ್ಶನ ನೀಡಿದ ನಂತರ ನಮ್ಮ ಹೃದಯಗಳನ್ನು ವಿಚಲಿತಗೊಳಿಸಬೇಡ. ನಿಮ್ಮ ಕರುಣೆಯನ್ನು ನಮಗೆ ನೀಡಿ: ನೀವು ಯಾವಾಗಲೂ ಕೊಡುವವರಾಗಿದ್ದೀರಿ.",
  "duaMeaning4": "ಕರ್ತನೇ, ನಾನು ಮತ್ತು ನನ್ನ ಸಂತತಿಯು ಪ್ರಾರ್ಥನೆಯನ್ನು ಮುಂದುವರಿಸಲು ಅನುಗ್ರಹಿಸು. ನಮ್ಮ ಕರ್ತನೇ, ನನ್ನ ಕೋರಿಕೆಯನ್ನು ಸ್ವೀಕರಿಸು.",
  "duaMeaning5": "ಮತ್ತು ದಯೆಯಿಂದ ಅವರ ಕಡೆಗೆ ವಿನಯದಿಂದ ನಿಮ್ಮ ರೆಕ್ಕೆಯನ್ನು ತಗ್ಗಿಸಿ ಮತ್ತು 'ಕರ್ತನೇ, ನಾನು ಚಿಕ್ಕವನಿದ್ದಾಗ ಅವರು ನನ್ನನ್ನು ನೋಡಿಕೊಂಡಂತೆ ಅವರ ಮೇಲೆ ಕರುಣಿಸು' ಎಂದು ಹೇಳಿ.",
  "duaMeaning6": "ಉದಾತ್ತನಾದ ದೇವರು, ನಿಜವಾಗಿಯೂ ನಿಯಂತ್ರಣದಲ್ಲಿರುವವನು. [ಪ್ರವಾದಿ], ಬಹಿರಂಗ ಪೂರ್ಣಗೊಳ್ಳುವ ಮೊದಲು ಪಠಿಸಲು ಆತುರಪಡಬೇಡಿ, ಆದರೆ ‘ಕರ್ತನೇ, ನನಗೆ ಜ್ಞಾನವನ್ನು ಹೆಚ್ಚಿಸು!’ ಎಂದು ಹೇಳಿ.",
  "duaMeaning7": "[ಪ್ರವಾದಿ] ಹೇಳಿ, ‘ಕರ್ತನೇ, ಕ್ಷಮಿಸು ಮತ್ತು ಕರುಣಿಸು: ನೀನು ಎಲ್ಲರಿಗಿಂತ ಹೆಚ್ಚು ಕರುಣಾಮಯಿ.",
  "duaMeaning8": "ಪ್ರಾರ್ಥಿಸುವವರು, 'ನಮ್ಮ ಪ್ರಭುವೇ, ನಮ್ಮ ಸಂಗಾತಿಗಳು ಮತ್ತು ಸಂತತಿಯಲ್ಲಿ ನಮಗೆ ಸಂತೋಷವನ್ನು ನೀಡು. ನಿಮ್ಮ ಬಗ್ಗೆ ತಿಳಿದಿರುವವರಿಗೆ ನಮಗೆ ಉತ್ತಮ ಉದಾಹರಣೆಗಳನ್ನು ನೀಡಿ.",
