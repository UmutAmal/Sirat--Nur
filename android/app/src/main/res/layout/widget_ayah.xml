<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_background"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_ayah_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4CAF50"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="Günün Ayeti / Ayah of the Day" />

        <TextView
            android:id="@+id/tv_ayah_arabic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_gravity="end"
            tools:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ" />

        <TextView
            android:id="@+id/tv_ayah_translation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#A0A0A0"
            android:textSize="10sp"
            tools:text="Rahman ve Rahim olan Allah'ın adıyla" />

        <TextView
            android:id="@+id/tv_ayah_reference"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            tools:text="Fatiha 1" />

    </LinearLayout>

</LinearLayout>
